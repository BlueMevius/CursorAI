; Engine configuration file.
; It's best edited using the editor and not directly,
; since the parameters here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Hungry G"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.2")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=980
window/size/viewport_height=700
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[audio]

buses/default_bus_layout="res://default_bus_layout.tres"

[rendering]

renderer/rendering_method="forward_plus"
textures/vram_compression/import_etc2_astc=true
